{
    "manifest_version": 3,
    "name": "CloudAuth",
    "version": "1.0",
    "description": "A secure vault for your sensitive data, protected by your cloud account.",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "http://localhost:4000/*"
    ],
    "action":{
        "default_popup": "popup.html",
        "default_title": "CloudAuth"
    }

}